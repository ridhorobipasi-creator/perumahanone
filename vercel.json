{
  "version": 2,
  "buildCommand": "sh scripts/vercel-build.sh",
  "outputDirectory": "perumahan-web/public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": [
        "perumahan-web/**"
      ]
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/perumahan-web/public/build/$1" },
    { "src": "/favicon.ico", "dest": "/perumahan-web/public/favicon.ico" },
    { "src": "/robots.txt", "dest": "/perumahan-web/public/robots.txt" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
