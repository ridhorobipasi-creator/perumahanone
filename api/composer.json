{
  "name": "vercel/laravel-bridge",
  "description": "Vercel builder hook for Laravel app located in perumahan-web",
  "type": "project",
  "scripts": {
    "vercel": [
      "sh -lc 'mkdir -p ../perumahan-web/bootstrap/cache && chmod -R 0777 ../perumahan-web/bootstrap/cache && composer install -d ../perumahan-web --no-dev --prefer-dist --optimize-autoloader --no-interaction'"
    ],
    "post-install-cmd": [
      "sh -lc 'mkdir -p ../perumahan-web/bootstrap/cache && chmod -R 0777 ../perumahan-web/bootstrap/cache && composer install -d ../perumahan-web --no-dev --prefer-dist --optimize-autoloader --no-interaction'"
    ],
    "post-update-cmd": [
      "sh -lc 'mkdir -p ../perumahan-web/bootstrap/cache && chmod -R 0777 ../perumahan-web/bootstrap/cache && composer install -d ../perumahan-web --no-dev --prefer-dist --optimize-autoloader --no-interaction'"
    ]
  }
}
